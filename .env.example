# Required: Google AI Studio API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Host port mapping (docker-compose only)
OPTIMUS_PORT=7778

# Optional: only needed if you run the app outside Docker without compose.
# In Docker, /data is set automatically in the image.
# SENTRYSEARCH_DATA_DIR=/data

# --- Web UI: sessions & SSO (OAuth 2.0 / OpenID Connect) ---
# Strong random secret for signing cookies (required in production).
# OPTIMUS_SESSION_SECRET=
# Set to true behind HTTPS so session cookies are not sent on plain HTTP.
# OPTIMUS_SESSION_HTTPS_ONLY=true

# OIDC provider (issuer URL without trailing slash, e.g. https://accounts.google.com)
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=

# Redirect URI must match your OAuth client EXACTLY (scheme, host, port, path).
# If unset, the app uses the URL of /auth/callback as seen by the server.
# Local Google OAuth: add BOTH if you use either host:
#   http://127.0.0.1:7778/auth/callback
#   http://localhost:7778/auth/callback
# Behind a reverse proxy, set this to the public URL and enable TRUST_PROXY=1.
# OIDC_REDIRECT_URI=https://your-domain/auth/callback

# Trust X-Forwarded-* from a reverse proxy (so redirect URI matches public URL).
# TRUST_PROXY=1
# FORWARDED_ALLOW_IPS=*

# First user becomes admin when the user table is empty (set before first login).
# OIDC_BOOTSTRAP_ADMIN_EMAIL=
